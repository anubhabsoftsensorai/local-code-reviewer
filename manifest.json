{
  "manifest_version": 3,
  "name": "Local Code Reviewer",
  "version": "1.0.0",
  "description": "Static code analysis and suggestions directly in your browser. No cloud, 100% local.",
  "permissions": ["activeTab", "sidePanel", "storage"],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"]
    }
  ],
  "action": {
    "default_title": "Open Code Reviewer"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "icons": {
    "16": "src/assets/icon16.png",
    "48": "src/assets/icon48.png",
    "128": "src/assets/icon128.png"
  }
}
